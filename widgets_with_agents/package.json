{
  "name": "widgets-with-agents",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "build": {
    "appId": "com.widgets-with-agents.app",
    "productName": "Personal Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "frontend/dist/**"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "scripts": {
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"wait-on http://localhost:5173 http://localhost:3001/api/health && electron .\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd frontend && ELECTRON=1 npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "puppeteer-core": "^24.37.5",
    "puppeteer-in-electron": "^3.0.5",
    "qrcode": "^1.5.4",
    "wwebjs-electron": "^1.34.2"
  }
}
